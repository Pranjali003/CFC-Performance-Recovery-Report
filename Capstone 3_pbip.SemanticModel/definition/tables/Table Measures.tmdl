	measure 'Composite Score' = ```
			
			AVERAGE('CFC Recovery status Data'[value])
			
			```
		lineageTag: 8f7454e8-5277-4551-959a-af15fc0abfe7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Composite Score Bin' =
			
			SWITCH(
			    TRUE(),
			    [Composite Score] < -0.6, "-0.7 to -0.6",
			    [Composite Score] < -0.5, "-0.6 to -0.5",
			    [Composite Score] < -0.4, "-0.5 to -0.4",
			    [Composite Score] < -0.3, "-0.4 to -0.3",
			    [Composite Score] < -0.2, "-0.3 to -0.2",
			    [Composite Score] < -0.1, "-0.2 to -0.1",
			    [Composite Score] <  0.0, "-0.1 to 0.0",
			    [Composite Score] >= 0.0, "0.0+"
			)
		lineageTag: bca0f9da-6bb1-4fd7-986e-6a5e6a18416b

	measure 'Baseline Status' =
			
			SWITCH(
			    TRUE(),
			    [Composite Score] < 0, "Below Baseline",
			    [Composite Score] = 0, "At Baseline",
			    [Composite Score] > 0, "Above Baseline"
			)
		lineageTag: 953a1a87-e438-4afd-9e19-a1e5211b4c0b

	measure 'Session Count' =
			
