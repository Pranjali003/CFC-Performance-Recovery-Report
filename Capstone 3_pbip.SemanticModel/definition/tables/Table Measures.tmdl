table 'Table Measures'
	lineageTag: 5f19da63-59f3-4a4b-9c48-260010ba7a33

	measure 'Muscle Soreness' = ```
			
			AVERAGEX(
			    FILTER(
			        'CFC Recovery status Data',
			        'CFC Recovery status Data'[metric] = "soreness_baseline_composite"
			            && NOT ISBLANK('CFC Recovery status Data'[value])
			    ),
			    ('CFC Recovery status Data'[value])
			)
			
			```
		lineageTag: 2086cc04-8892-497e-bd67-bfdc65aca447

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Fatigue =
			
			AVERAGEX(
			    FILTER(
			        'CFC Recovery status Data',
			        'CFC Recovery status Data'[metric] IN {
			            "subjective_baseline_composite",
			            "sleep_baseline_composite"
			        } && NOT ISBLANK('CFC Recovery status Data'[value])
			    ),
			    'CFC Recovery status Data'[value]
			)
		lineageTag: 11842303-d3b2-4c6c-b138-ecafafd1e2da

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Inflammation =
			
			AVERAGEX(
			    FILTER(
			        'CFC Recovery status Data',
			        'CFC Recovery status Data'[metric] IN {
			            "bio_baseline_composite"
			        } && NOT ISBLANK('CFC Recovery status Data'[value])
			    ),
			    'CFC Recovery status Data'[value]
			)
		lineageTag: 21a7ea82-ed57-43c1-938d-a50fec839cb0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Most Recent' =
			
			
			VAR _lastDate =
			    CALCULATE(
			        MAX('CFC Recovery status Data'[sessionDate]),
			        'CFC Recovery status Data'[metric] = "bio_baseline_composite",
			        NOT ISBLANK('CFC Recovery status Data'[value])
			    )
			RETURN
			CALCULATE(
			    AVERAGE('CFC Recovery status Data'[value]),
			    'CFC Recovery status Data'[metric] = "bio_baseline_composite",
			    'CFC Recovery status Data'[sessionDate] = _lastDate
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: bfc01d8c-534c-4fd1-994e-7bc562f53fd9

	measure '14 Day Avg' = ```
			
			CALCULATE(
			    AVERAGE('CFC Recovery status Data'[value]),
			    DATESINPERIOD(
			        'CFC Recovery status Data'[sessionDate],
			        MAX('CFC Recovery status Data'[sessionDate]),
			        -14,
			        DAY
			    )
			)
			
			```
		formatString: 0
		lineageTag: b0ca42aa-31e3-4cc4-8056-d0ed6531ae49

