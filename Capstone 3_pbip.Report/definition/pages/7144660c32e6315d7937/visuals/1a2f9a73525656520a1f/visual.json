                ]
              },
              {
                "textRuns": [
                  {
                    "value": "The Squad Sense dashboard is a dynamic, data‑driven monitoring tool designed to support football players, coaches, and performance staff by providing real‑time insights into player recovery. Drawing from biometric and perception session‑based inputs, the dashboard surfaces meaningful trends and early warnings that can inform training decisions, reduce injury risk, and optimize performance. Each metric is tracked consistently over time to flag values that fall outside of personalized thresholds, with intuitive visual cues and alerting mechanisms built in for proactive support.",
                    "textStyle": {
                      "fontFamily": "Segoe UI",
                      "fontSize": "8pt",
                      "color": "#333333"
                    }
                  }
                ]
              },
              {
                "textRuns": [
